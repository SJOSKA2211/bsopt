# Database Configuration
DATABASE_URL=postgresql://admin:<REPLACE_WITH_SECURE_PASSWORD>@postgres:5432/bsopt
DB_PASSWORD=<REPLACE_WITH_SECURE_PASSWORD>

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:<REPLACE_WITH_SECURE_PASSWORD>@rabbitmq:5672/
RABBITMQ_PASSWORD=<REPLACE_WITH_SECURE_PASSWORD>

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000

# Broker API Keys (Optional)
IBKR_ACCOUNT=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market Data
ALPHA_VANTAGE_API_KEY=
YAHOO_FINANCE_ENABLED=true

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@bsopt.com

# OpenAI API (Optional - for NLP features)
OPENAI_API_KEY=

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=10000
RATE_LIMIT_ENTERPRISE=0

# Performance
MAX_WORKERS=4
CELERY_CONCURRENCY=4
