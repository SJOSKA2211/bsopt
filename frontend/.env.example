# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Black-Scholes Option Pricing Platform
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_ANALYTICS=false

# Authentication
VITE_TOKEN_STORAGE_KEY=bs_auth_token
VITE_REFRESH_TOKEN_KEY=bs_refresh_token

# Chart Configuration
VITE_DEFAULT_CHART_THEME=light
VITE_ENABLE_3D_CHARTS=true
