# =====================================================================
# DOCKERIGNORE - FRONTEND (REACT/VITE)
# =====================================================================
# Purpose: Exclude unnecessary files from frontend build context
# Impact: Faster builds, smaller context
# Estimated context reduction: 70-80%
# =====================================================================

# =====================================================================
# Dependencies (installed fresh in container)
# =====================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================================================
# Build Output (generated during build)
# =====================================================================
dist/
build/
.vite/
*.local

# =====================================================================
# Version Control
# =====================================================================
.git
.gitignore
.gitattributes

# =====================================================================
# Testing
# =====================================================================
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
test/
tests/

# =====================================================================
# Environment Files
# =====================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# =====================================================================
# IDEs and Editors
# =====================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# =====================================================================
# Documentation
# =====================================================================
*.md
!README.md
docs/

# =====================================================================
# Linting and Formatting
# =====================================================================
.eslintcache
.prettierignore

# =====================================================================
# Docker Files
# =====================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# =====================================================================
# CI/CD
# =====================================================================
.github/
.gitlab-ci.yml
.travis.yml

# =====================================================================
# OS Files
# =====================================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================================
# Logs
# =====================================================================
logs/
*.log

# =====================================================================
# Temporary Files
# =====================================================================
tmp/
temp/
.tmp/

# =====================================================================
# Storybook (if used)
# =====================================================================
storybook-static/
.storybook/

# =====================================================================
# Keep These Files
# =====================================================================
# The following are explicitly included in COPY commands:
# - package.json
# - package-lock.json
# - src/
# - public/
# - index.html
# - vite.config.ts
# - tsconfig.json
# =====================================================================
