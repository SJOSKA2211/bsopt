# =====================================================================
# DOCKERIGNORE - ROOT PROJECT (API & WORKER)
# =====================================================================
# Purpose: Exclude unnecessary files from Docker build context
# Impact: Faster builds, smaller context, better layer caching
# Estimated context reduction: 80-90%
# =====================================================================

# =====================================================================
# Version Control
# =====================================================================
.git
.gitignore
.gitattributes
.github

# =====================================================================
# Python
# =====================================================================
# Virtual environments
venv/
env/
ENV/
.venv/
*.pyenv

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Testing
.pytest_cache/
.coverage
.coveragerc
coverage.xml
htmlcov/
.tox/
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# =====================================================================
# IDEs and Editors
# =====================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.code-workspace

# =====================================================================
# Documentation (not needed in container)
# =====================================================================
*.md
!README.md
docs/
*.txt
!requirements.txt
!requirements-auth.txt
!requirements_api.txt

# =====================================================================
# Development and Testing
# =====================================================================
tests/
test_*.py
*_test.py
benchmarks/
examples/
notebooks/

# =====================================================================
# Jupyter
# =====================================================================
.ipynb_checkpoints
*.ipynb

# =====================================================================
# Logs and Temporary Files
# =====================================================================
logs/
*.log
*.log.*
tmp/
temp/
.tmp/

# =====================================================================
# Data Files (should be mounted, not copied)
# =====================================================================
data/
*.csv
*.json
*.xml
*.xlsx
*.db
*.sqlite
*.sqlite3

# =====================================================================
# ML Models (should be mounted or pulled from registry)
# =====================================================================
models/
*.pkl
*.h5
*.pt
*.pth
*.onnx
mlruns/

# =====================================================================
# Docker and Container Files
# =====================================================================
Dockerfile*
.dockerignore
docker-compose*.yml
.docker/

# =====================================================================
# CI/CD and Deployment
# =====================================================================
.gitlab-ci.yml
.travis.yml
.circleci/
.github/
k8s/
kubernetes/
helm/
terraform/

# =====================================================================
# Environment and Secrets
# =====================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/

# =====================================================================
# Frontend (not needed in backend containers)
# =====================================================================
frontend/
node_modules/
package.json
package-lock.json
tsconfig.json
vite.config.ts
*.config.js

# =====================================================================
# Build Artifacts
# =====================================================================
*.tar.gz
*.zip
*.rar

# =====================================================================
# OS Files
# =====================================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================================
# Performance and Monitoring (Allow needed files)
# =====================================================================
# performance/ (Removed from ignore)
*.prof
*.trace

# =====================================================================
# Scripts (unless needed in container)
# =====================================================================
scripts/
*.sh
!setup.sh

# =====================================================================
# Design Files
# =====================================================================
designs/
*.sketch
*.fig
*.psd
*.ai

# =====================================================================
# Backup Files
# =====================================================================
*.bak
*.backup
*.old
*~

# =====================================================================
# Keep These Files (Examples)
# =====================================================================
# Uncomment/modify based on your needs:
# !src/**
# !cli.py
# !pyproject.toml
# !requirements.txt
# =====================================================================
